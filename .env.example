# 🏥 ImpactPulse Environment Configuration Example
# Copy this file to 'frontend/.env' and fill in your Firebase project credentials.

# --- Firebase Cloud Configuration ---
# You can find these values in your Firebase Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# --- Optional Configurations ---
VITE_APP_NAME=ImpactPulse
VITE_REGION=Global
